  "html": "<!-- HTML Template -->\n{% for bundle_row in doc.table_bundle_details if bundle_row.sticker %}\n  {% set parent_item = frappe.get_doc(\"Bundle Creation Item\", bundle_row.parent_item_id) %}\n  {% set sales_order = frappe.get_doc(\"Sales Order\", parent_item.sales_order) if parent_item.sales_order else None %}\n  {% set sbu_name = frappe.db.get_value(\"Strategic Business Unit\", doc.strategic_business_unit, \"sbu_name\") or doc.strategic_business_unit or \"\" %}\n  \n  <div class=\"label-page\">\n    <div class=\"label-container\">\n      <table class=\"label-table\" cellspacing=\"0\" cellpadding=\"0\">\n        <thead>\n          <tr class=\"row-header\">\n            <td colspan=\"2\" class=\"sbu-header\">{{ sbu_name }}</td>\n          </tr>\n        </thead>\n        <tbody>\n          <tr class=\"row-data\">\n            <td class=\"cell-left\">Buyer: {{ sales_order.customer if sales_order else \"\" }}</td>\n            <td class=\"cell-right\">Date: {{ frappe.utils.now_datetime().strftime(\"%d/%m/%Y\") }}</td>\n          </tr>\n          <tr class=\"row-data\">\n            <td class=\"cell-left\">OCN: {{ parent_item.sales_order or \"\" }}</td>\n            <td class=\"cell-right\">\n              Bundle No: {{\n                bundle_row.bundle_id.split('-')[-2:] | join('-')\n                if bundle_row.bundle_id and bundle_row.bundle_id.count('-') >= 1\n                else bundle_row.bundle_id or \"\"\n              }}\n            </td>\n          </tr>\n          <tr class=\"row-data\">\n            <td class=\"cell-left\">Style: {{ doc.style_number or \"\" }}</td>\n            <td class=\"cell-right\">Size: {{ parent_item.size }}</td>\n          </tr>\n          <tr class=\"row-data\">\n            <td class=\"cell-left\">Lot No: {{ bundle_row.shade or \"\" }}</td>\n            <td class=\"cell-right\">Pcs: {{ bundle_row.unitsbundle or \"\" }}</td>\n          </tr>\n          <tr class=\"row-data\">\n            <td class=\"cell-left\">Component: {{ bundle_row.component or \"\" }}</td>\n            <td class=\"cell-right\">Colour: {{ doc.color or \"\" }}</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n{% endfor %}\n\n<!-- CSS Styling -->\n<style>\n/* Thermal Printer Optimized Styling - 203 DPI */\n@page {\n  size: 80mm 50mm;\n  margin: 0;\n  padding: 0;\n}\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  margin: 0;\n  padding: 0;\n  font-family: 'Arial', 'Helvetica', sans-serif;\n  font-size: 8pt;\n  line-height: 1.1;\n  -webkit-print-color-adjust: exact;\n  print-color-adjust: exact;\n  image-rendering: -webkit-optimize-contrast;\n  image-rendering: crisp-edges;\n}\n\n.label-page {\n  width: 80mm;\n  height: 50mm;\n  max-height: 50mm;\n  page-break-after: always;\n  break-after: page;\n  page-break-inside: avoid;\n  break-inside: avoid;\n  position: relative;\n  overflow: hidden;\n  display: block;\n  box-sizing: border-box;\n}\n\n.label-page:last-child {\n  page-break-after: avoid;\n  break-after: avoid;\n}\n\n.label-container {\n  width: 100%;\n  height: 48mm;\n  padding: 1mm;\n  box-sizing: border-box;\n}\n\n.label-table {\n  width: 100%;\n  height: 46mm;\n  border-collapse: collapse;\n  table-layout: fixed;\n  border: 0.5pt solid #000;\n}\n\n/* Row Heights */\n.row-header {\n  height: 8mm;\n}\n\n.row-data {\n  height: 7mm;\n}\n\n/* Cell Styling - Wrap without breaking words */\n.label-table td {\n  padding: 0.5mm 1mm;\n  vertical-align: middle !important;\n  border: 0.5pt solid #000;\n  font-family: 'Arial', 'Helvetica', sans-serif;\n  font-size: 8pt;\n  font-weight: normal;\n  color: #000;\n  overflow: visible !important;\n  text-overflow: ellipsis !important;\n  white-space: normal !important;\n  word-wrap: break-word !important;\n  word-break: normal !important; /* Changed from break-all to normal */\n  overflow-wrap: break-word !important; /* Added for better wrapping */\n  text-rendering: geometricPrecision;\n  -webkit-font-smoothing: none;\n  -moz-osx-font-smoothing: grayscale;\n  display: table-cell !important;\n  max-width: 0 !important;\n}\n\n/* Column Widths */\n.cell-left {\n  width: 50%;\n  text-align: left;\n}\n\n.cell-right {\n  width: 50%;\n  text-align: left;\n}\n\n/* Header Styling */\n.sbu-header {\n  text-align: center;\n  font-weight: bold;\n  font-family: 'Arial', 'Helvetica', sans-serif;\n  font-size: 10pt;\n  text-transform: uppercase;\n  color: #000;\n  white-space: normal !important;\n  word-wrap: break-word !important;\n  word-break: normal !important; /* Changed from break-all */\n  overflow-wrap: break-word !important;\n}\n\n/* Print-specific adjustments for thermal printer */\n@media print {\n  @page {\n    size: 80mm 50mm;\n    margin: 0 !important;\n    padding: 0 !important;\n  }\n  \n  html, body {\n    width: 80mm !important;\n    height: 50mm !important;\n    margin: 0 !important;\n    padding: 0 !important;\n    -webkit-print-color-adjust: exact !important;\n    print-color-adjust: exact !important;\n  }\n  \n  .label-page {\n    width: 80mm !important;\n    height: 50mm !important;\n    max-height: 50mm !important;\n    page-break-after: always !important;\n    break-after: page !important;\n  }\n  \n  .label-page:last-child {\n    page-break-after: avoid !important;\n    break-after: avoid !important;\n  }\n  \n  .label-container {\n    padding: 1mm !important;\n  }\n  \n  .label-table {\n    border: 0.5pt solid #000 !important;\n    border-collapse: collapse !important;\n  }\n  \n  .label-table td {\n    border: 0.5pt solid #000 !important;\n    font-family: 'Arial', 'Helvetica', sans-serif !important;\n    font-size: 8pt !important;\n    padding: 0.5mm 1mm !important;\n    color: #000 !important;\n    -webkit-print-color-adjust: exact !important;\n    print-color-adjust: exact !important;\n    text-rendering: geometricPrecision !important;\n    -webkit-font-smoothing: none !important;\n    overflow: visible !important;\n    white-space: normal !important;\n    word-wrap: break-word !important;\n    word-break: normal !important; /* Changed from break-all to normal */\n    overflow-wrap: break-word !important;\n  }\n  \n  .sbu-header {\n    font-size: 10pt !important;\n    font-weight: bold !important;\n    font-family: 'Arial', 'Helvetica', sans-serif !important;\n    white-space: normal !important;\n    word-wrap: break-word !important;\n    word-break: normal !important; /* Changed from break-all */\n    overflow-wrap: break-word !important;\n  }\n  \n  .row-header {\n    height: 8mm !important;\n  }\n  \n  .row-data {\n    height: 7mm !important;\n  }\n}\n</style>",
