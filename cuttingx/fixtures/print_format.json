  "css": "body {\n    font-family: Arial, sans-serif;\n    font-size: 14px;\n    margin: 0;\n    padding: 10px;\n}\n\n.label-container {\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: space-between;\n    gap: 20px;\n}\n\n.label {\n    width: 100%; /* For 2 per row (use 31% for 3 per row) */\n    border: 1px solid #000;\n    padding: 8px;\n    box-sizing: border-box;\n    page-break-inside: avoid;\n}\n\ntable {\n    width: 100%;\n    border-collapse: collapse;\n}\n\ntd {\n    border: 1px solid #000;\n    padding: 4px;\n    vertical-align: top;\n}\n\n.qr-img, .barcode-img {\n    width: 100px;\n    height: auto;\n    display: block;\n    margin: 0 auto;\n}\n\n@media print {\n    .label {\n        page-break-inside: avoid;\n    }\n}",
  "custom_format": 1,
