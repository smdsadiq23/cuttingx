  "css": "  /* Default: for screen preview — large and scrollable */\n  .factory-ocr-container {\n    font-family: 'Courier New', Courier, monospace;\n    font-size: 12px;\n    margin: 0;\n    padding: 0;\n    min-width: 1200px;\n  }\n\n  /* Scrollable preview in browser */\n  @media screen {\n    .print-preview-scroll {\n      max-width: 100%;\n      overflow-x: auto;\n      padding: 10px;\n      border: 1px solid #ddd;\n      margin: 10px 0;\n    }\n  }\n\n  /* Only for Frappe's PDF button (wkhtmltopdf) */\n  @media print and (max-width: 210mm) {\n    .factory-ocr-container {\n      font-size: 9.5px !important;\n      min-width: auto !important;\n      width: 100% !important;\n    }\n    .main-table {\n      table-layout: fixed !important;\n      width: 100% !important;\n    }\n    .main-table th,\n    .main-table td {\n      padding: 1.5px !important;\n      word-wrap: break-word !important;\n      white-space: normal !important;\n    }\n    .header-table td {\n      padding: 2px !important;\n    }\n  }\n\n  /* Table styles */\n  .header-title {\n    text-align: center;\n    font-weight: bold;\n    font-size: 14px;\n    margin-bottom: 5px;\n  }\n\n  .header-table,\n  .main-table,\n  .footer-table {\n    border-collapse: collapse;\n    width: 100%;\n    border: 2px solid black;\n  }\n\n  .header-table td,\n  .main-table th,\n  .main-table td,\n  .footer-table td {\n    padding: 3px;\n    text-align: center;\n  }\n\n  .main-table th {\n    font-weight: bold;\n  }\n\n  .main-table td {\n    text-align: right;\n  }\n\n  .main-table td:first-child,\n  .main-table td:nth-child(2) {\n    text-align: left;\n  }\n\n  .totals-row td {\n    font-weight: bold;\n  }\n\n  .ship-only-heading {\n    text-align: center;\n    margin: 10px 0;\n    font-weight: bold;\n    font-size: 13px;\n  }\n\n  .footer-table td {\n    font-size: 12px;\n  }\n\n  .footer-notes {\n    font-style: italic;\n    vertical-align: top;\n    width: 70%;\n  }\n\n  .footer-metrics {\n    width: 30%;\n    text-align: center;\n  }\n\n  .footer-metrics-title {\n    font-weight: bold;\n    font-size: 14px;\n  }\n\n  .footer-metrics-value {\n    font-size: 20px;\n    font-weight: bold;\n    margin-top: 5px;\n  }\n\n  .factory-head-sign {\n    margin-top: 20px;\n    text-align: center;\n    font-weight: bold;\n    font-size: 13px;\n  }",
  "custom_format": 1,
  "default_print_language": "en",
