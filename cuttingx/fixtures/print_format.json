  "font_size": 14,
  "format_data": null,
  "html": "<!-- Frappe Print Format for Purchase Order -->\n<style>\n* {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n}\n\nbody {\n    font-family: Arial, sans-serif;\n    background: white;\n    margin: 0;\n    padding: 0;\n}\n\n.print-format-full-width {\n    padding: 5mm 10mm !important;\n    margin: 0 !important;\n}\n\n.header {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    border: 2px solid #000;\n    border-radius: 8px; /* Keep rounded on header */\n    padding: 10px;\n    margin-bottom: 8px;\n    background: #fff;\n}\n\n.company-logo {\n    width: 70px;\n    height: 70px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n}\n\n.company-logo img {\n    max-width: 100%;\n    max-height: 100%;\n    object-fit: contain;\n}\n\n.company-info {\n    flex: 1;\n    text-align: center;\n    padding: 0 12px;\n    font-size: 12px;\n}\n\n.company-name {\n    font-size: 18px;\n    font-weight: bold;\n    margin-bottom: 4px;\n    color: #000;\n}\n\n.company-address {\n    line-height: 1.3;\n}\n\n.gst-info {\n    font-size: 11px;\n    margin-top: 4px;\n}\n\n.header-right .approved-badge {\n    background: #fff;\n    padding: 6px 12px;\n    text-align: center;\n    font-weight: bold;\n    font-size: 14px;\n    border: 1px solid #000;\n    color: #000;\n    white-space: nowrap;\n}\n\n.doc-title {\n    text-align: center;\n    color: #ff0066;\n    font-size: 16px;\n    font-weight: bold;\n    margin: 10px 0;\n}\n\n.po-details {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n    margin-bottom: 12px;\n}\n\n.detail-section {\n    border: 1px solid #000;\n    border-radius: 6px;\n    padding: 8px;\n    background: #fff;\n    font-size: 12px;\n}\n\n.detail-row {\n    display: flex;\n    margin-bottom: 6px;\n    font-size: 12px;\n}\n\n.detail-row:last-child {\n    margin-bottom: 0;\n}\n\n.detail-label {\n    font-weight: bold;\n    min-width: 110px;\n    color: #000;\n}\n\n.detail-value {\n    ₹: #e91e63;\n    flex: 1;\n}\n\n.vendor-delivery {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n    margin-bottom: 12px;\n}\n\n.section-box {\n    border: 1px solid #000;\n    border-radius: 6px;\n    padding: 8px;\n    min-height: 100px;\n    background: #fff;\n    font-size: 11px;\n}\n\n.section-title {\n    font-weight: bold;\n    margin-bottom: 6px;\n    color: #000;\n    font-size: 12px;\n}\n\n.section-content {\n    line-height: 1.4;\n    color: #000;\n}\n\n.section-content strong {\n    color: #ff0000;\n}\n\n/* ✅ ITEMS TABLE – Sharp borders (no rounding) */\n.items-table {\n    width: 100%;\n    border-collapse: collapse;\n    margin-bottom: 12px;\n    font-size: 11px;\n    border: 1px solid #000;\n    border-radius: 0; /* Explicitly no rounding */\n}\n\n.items-table th {\n    background: #CCE5A3;\n    border: 1px solid #000;\n    padding: 4px;\n    text-align: left;\n    font-weight: bold;\n    color: #000;\n}\n\n.items-table td {\n    border: 1px solid #000;\n    padding: 6px;\n    vertical-align: top;\n    background: #fff;\n    color: #000;\n}\n\n.items-table td.text-right {\n    text-align: right;\n}\n\n.total-row td {\n    background: #fff !important;\n    font-weight: bold;\n    color: #000;\n}\n\n.tax-table-container {\n    margin-top: 8px;\n    margin-bottom: 12px;\n    float: right;\n    width: auto;\n    max-width: 250px;\n    border: 1px solid #000;\n    border-radius: 0;\n    background: #fff;\n}\n\n.tax-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 12px;\n}\n\n.tax-table .tax-header {\n    background-color: #CCE5A3;\n    padding: 6px 8px;\n    text-align: center;\n    font-weight: bold;\n    font-size: 14px;\n    border-bottom: 1px solid #000;\n    color: #000 !important;\n}\n\n.tax-table td {\n    padding: 3px 8px;\n    border: 1px solid #000;\n    background: #fff;\n    color: #000;\n}\n\n.tax-table .tax-label {\n    text-align: left;\n    padding-left: 10px;\n}\n\n.tax-table .tax-value {\n    text-align: right;\n    padding-right: 10px;\n}\n\n/* Highlight NET AMOUNT */\n.net-amount-label,\n.net-amount-value {\n    font-size: 14px;\n    font-weight: bold;\n}\n\n.amount-words {\n    border: 1px solid #000;\n    border-radius: 6px;\n    padding: 8px;\n    margin-bottom: 12px;\n    font-size: 12px;\n    background: #fff;\n}\n\n.terms-section {\n    border: 1px solid #000;\n    border-radius: 6px;\n    padding: 8px;\n    margin-bottom: 15px;\n    min-height: 60px;\n    font-size: 11px;\n    background: #fff;\n}\n\n.signatures {\n    display: grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    gap: 12px;\n    margin-top: 20px;\n}\n\n.signature-box {\n    text-align: center;\n}\n\n.signature-line {\n    border-top: 1px solid #333;\n    margin-top: 25px;\n    padding-top: 4px;\n    font-size: 11px;\n    font-weight: bold;\n    color: #000;\n}\n\n/* Clear float after tax table */\n.clearfix::after {\n    content: \"\";\n    display: table;\n    clear: both;\n}\n</style>\n\n<div class=\"print-format print-format-full-width\" style=\"padding: 5mm 10mm; margin: 0;\">\n    <!-- Header -->\n    <div class=\"header\">\n        <div class=\"company-logo\">\n            <img src=\"/files/Classic Apparel Logo.jpg\" alt=\"Company Logo\" />\n        </div>\n        <div class=\"company-info\">\n            <div class=\"company-name\">CLASSIC APPAREL</div>\n            <div class=\"company-address\">\n                {% if doc.company_address %}\n                    {{ frappe.get_doc(\"Address\", doc.company_address).address_line1 or \"\" }}<br>\n                    {{ frappe.get_doc(\"Address\", doc.company_address).city or \"\" }},\n                    {{ frappe.get_doc(\"Address\", doc.company_address).state or \"\" }}\n                    {{ frappe.get_doc(\"Address\", doc.company_address).pincode or \"\" }}\n                {% else %}\n                    SF. NO. 86/1, KANIYAMPOONDI, VANJIPALAYAM (PO),<br>\n                    MANGALAM (VIA), 641663 TIRUPUR, TAMILNADU, INDIA\n                {% endif %}\n            </div>\n            <div class=\"gst-info\">\n                GST NO: {{ doc.tax_id or \"33ALDPD4848F1ZF\" }} / PAN NO: {{ doc.pan or \"ALDPD4848F\" }}\n            </div>\n        </div>\n    </div>\n    \n    <!-- Document Title -->\n    <div class=\"doc-title\">{{ doc.custom_purchase_order_type or \"DYED YARN PURCHASE ORDER\" }}</div>\n    \n    <!-- PO Details -->\n    <div class=\"po-details\">\n        <div class=\"detail-section\">\n            <div class=\"detail-row\">\n                <span class=\"detail-label\">PO No</span>\n                <span class=\"detail-value\">: {{ doc.name }}</span>\n            </div>\n            <div class=\"detail-row\">\n                <span class=\"detail-label\">PO Date</span>\n                <span class=\"detail-value\">: {{ frappe.utils.formatdate(doc.transaction_date, \"dd/mm/yyyy\") if doc.transaction_date else \"\" }}</span>\n            </div>\n            <div class=\"detail-row\">\n                <span class=\"detail-label\">Order Type</span>\n                <span class=\"detail-value\">: {{ doc.custom_order_method or \"\" }}</span>\n            </div>\n        </div>\n        <div class=\"detail-section\">\n            <div class=\"detail-row\">\n                <span class=\"detail-label\">Payment Terms</span>\n                <span class=\"detail-value\">: {{ doc.payment_terms_template or \"\" }}</span>\n            </div>\n            <div class=\"detail-row\">\n                <span class=\"detail-label\">Buyer</span>\n                <span class=\"detail-value\">: {{ doc.custom_buyer or \"\" }}</span>\n            </div>\n            <div class=\"detail-row\">\n                <span class=\"detail-label\">Season</span>\n                <span class=\"detail-value\">: {{ doc.custom_season or \"\" }}</span>\n            </div>\n        </div>\n    </div>\n    \n    <!-- Vendor and Delivery Info -->\n    <div class=\"vendor-delivery\">\n        <div class=\"section-box\">\n            <div class=\"section-title\">VENDOR :</div>\n            <div class=\"section-content\">\n                <strong>{{ doc.supplier or \"\" }}</strong><br>\n                {% if doc.supplier_address %}\n                    {% set addr = frappe.get_doc(\"Address\", doc.supplier_address) %}\n                    {% if addr.address_line1 %}{{ addr.address_line1 }}<br>{% endif %}\n                    {% if addr.address_line2 %}{{ addr.address_line2 }}<br>{% endif %}\n                    {% set city_state_pin = [addr.city, addr.state, addr.pincode] | select | join(\", \") %}\n                    {% if city_state_pin %}{{ city_state_pin }}<br>{% endif %}\n                    {% if addr.country and addr.country != \"India\" %}{{ addr.country }}<br>{% endif %}\n                {% elif doc.address_display %}\n                    {{ doc.address_display | replace(\"\\n\", \"<br>\") }}\n                {% endif %}\n                {% if addr.phone or addr.email_id %}\n                    <br>\n                    {% if addr.phone %}Phone: {{ addr.phone }}<br>{% endif %}\n                    {% if addr.email_id %}Email: {{ addr.email_id }}<br>{% endif %}\n                {% endif %}\n            </div>\n        </div>\n        <div class=\"section-box\">\n            <div class=\"section-title\">DELIVERY TO :</div>\n            <div class=\"section-content\">\n                <strong>CLASSIC APPAREL</strong><br>\n                {% if doc.shipping_address %}\n                    {% set addr = frappe.get_doc(\"Address\", doc.shipping_address) %}\n                    {% if addr.address_line1 %}{{ addr.address_line1 }}<br>{% endif %}\n                    {% if addr.address_line2 %}{{ addr.address_line2 }}<br>{% endif %}\n                    {% set city_state_pin = [addr.city, addr.state, addr.pincode] | select | join(\", \") %}\n                    {% if city_state_pin %}{{ city_state_pin }}<br>{% endif %}\n                    {% if addr.country and addr.country != \"India\" %}{{ addr.country }}<br>{% endif %}\n                {% else %}\n                    SF. NO. 86/1, KANIYAMPOONDI<br>\n                    VANJIPALAYAM (PO), MANGALAM (VIA)<br>\n                    TIRUPUR, TAMILNADU, 641663<br>\n                    INDIA\n                {% endif %}\n                {% if doc.contact_display or doc.contact_mobile or doc.contact_email %}\n                    {% if doc.contact_display %}ATTN: {{ doc.contact_display }}<br>{% endif %}\n                    {% if doc.contact_mobile %}Phone: {{ doc.contact_mobile }}<br>{% endif %}\n                    {% if doc.contact_email %}Email: {{ doc.contact_email }}<br>{% endif %}\n                {% endif %}\n            </div>\n        </div>\n    </div>\n    \n    <!-- Items Table -->\n    <table class=\"items-table\">\n        <thead>\n            <tr>\n                <th style=\"width: 4%;\">SN</th>\n                <th style=\"width: 51%;\">Yarn Description</th>\n                <th style=\"width: 8%;\">Uom</th>\n                <th style=\"width: 8%;\">Qty</th>\n                <th style=\"width: 12%;\">Rate</th>\n                <th style=\"width: 17%;\">Amount</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for item in doc.items %}\n            <tr>\n                <td>{{ loop.index }}</td>\n                <td>\n                    {{ item.item_code or \"\" }}\n                    {% if item.description and item.description not in [item.item_name, item.item_code] %}\n                        <br><small>{{ item.description }}</small>\n                    {% endif %}\n                </td>\n                <td>{{ item.uom or \"\" }}</td>\n                <td class=\"text-right\">{{ item.qty or 0 }}</td>\n                <td class=\"text-right\">{{ frappe.utils.fmt_money(item.rate, currency=doc.currency) }}</td>\n                <td class=\"text-right\">{{ frappe.utils.fmt_money(item.amount, currency=doc.currency) }}</td>\n            </tr>\n            {% endfor %}\n            <tr class=\"total-row\">\n                <td colspan=\"3\" style=\"text-align: center;\">GRAND TOTAL</td>\n                <td class=\"text-right\">{{ doc.total_qty or 0 }}</td>\n                <td></td>\n                <td class=\"text-right\">{{ frappe.utils.fmt_money(doc.total, currency=doc.currency) }}</td>\n            </tr>\n        </tbody>\n    </table>\n    \n    <!-- Tax Details - Right-Aligned Table -->\n    <div class=\"tax-table-container\">\n        <table class=\"tax-table\">\n            <thead>\n                <tr>\n                    <th colspan=\"2\" class=\"tax-header\">Tax Details</th>\n                </tr>\n            </thead>\n            <tbody>\n                {% for tax in doc.taxes %}\n                <tr>\n                    <td class=\"tax-label\">{{ tax.description }}:</td>\n                    <td class=\"tax-value\">{{ frappe.utils.fmt_money(tax.tax_amount, currency=doc.currency) }}</td>\n                </tr>\n                {% endfor %}\n                {% if doc.rounding_adjustment %}\n                <tr>\n                    <td class=\"tax-label\">ROUNDOFF:</td>\n                    <td class=\"tax-value\">{{ frappe.utils.fmt_money(doc.rounding_adjustment, currency=doc.currency) }}</td>\n                </tr>\n                {% endif %}\n                <tr>\n                    <td class=\"tax-label net-amount-label\">NET AMOUNT:</td>\n                    <td class=\"tax-value net-amount-value\">{{ frappe.utils.fmt_money(doc.rounded_total, currency=doc.currency) }}</td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n    <div class=\"clearfix\"></div>\n    \n    <!-- Amount in Words -->\n    <div class=\"amount-words\">\n        <strong>Amount In Words:</strong><br>\n        {{ frappe.utils.money_in_words(doc.rounded_total, doc.currency) }}\n    </div>\n    \n    <!-- Terms and Conditions -->\n    <div class=\"terms-section\">\n        <strong>Terms and Conditions:</strong><br>\n        {{ doc.terms or \"\" }}\n    </div>\n    \n    <!-- Signatures -->\n    <div class=\"signatures\">\n        <div class=\"signature-box\">\n            <div class=\"signature-line\">Prepared By</div>\n        </div>\n        <div class=\"signature-box\">\n            <div class=\"signature-line\">Checked By</div>\n        </div>\n        <div class=\"signature-box\">\n            <div class=\"signature-line\">Authorized By<br><small>For {{ doc.company or \"Classic Apparel\" }}</small></div>\n        </div>\n    </div>\n</div>",
