  "font_size": 14,
  "format_data": null,
  "html": "\n\n<div class=\"print-preview-scroll\">\n  <div class=\"factory-ocr-container\">\n\n    <!-- Header -->\n    <div class=\"header-title\">\n      URBAN VIBE APPARELS PVT LTD - FACTORY OCR\n    </div>\n\n    <table class=\"header-table\" border=\"1\" cellpadding=\"3\" cellspacing=\"0\">\n      <tr>\n        <td style=\"width: 8%; font-weight: bold;\">BUYER</td>\n        <td style=\"width: 15%;\">{{ doc.buyer }}</td>\n        <td style=\"width: 8%; font-weight: bold;\">OCN</td>\n        <td style=\"width: 15%;\">{{ doc.ocn }}</td>\n        <td style=\"width: 8%; font-weight: bold;\">DATE</td>\n        <td style=\"width: 15%;\"></td>\n        <td style=\"width: 8%; font-weight: bold;\">No.</td>\n        <td style=\"width: 15%;\"></td>\n      </tr>\n      <tr>\n        <td style=\"font-weight: bold;\">FACTORY</td>\n        <td colspan=\"7\"></td>\n      </tr>\n    </table>\n\n    <div class=\"ship-only-heading\">Ship Only</div>\n\n    <!-- Main Table -->\n    <table class=\"main-table\" border=\"1\" cellpadding=\"3\" cellspacing=\"0\">\n      <thead>\n        <tr>\n          <th style=\"width: 10%;\">Style</th>\n          <th style=\"width: 10%;\">Color</th>\n          <th style=\"width: 8%;\">Order<br>Qty</th>\n          <th style=\"width: 8%;\">Cut<br>Qty</th>\n          <th style=\"width: 8%;\">Bhiwandi</th>\n          <th style=\"width: 8%;\">Isnapur</th>\n          <th style=\"width: 8%;\">Vadadora</th>\n          <th style=\"width: 8%;\">Total<br>Ship Qty</th>\n          <th style=\"width: 8%;\">Good<br>Garments</th>\n          <th style=\"width: 8%;\">Rejected<br>Garments</th>\n          <th style=\"width: 8%;\">Rejected<br>Panels</th>\n          <th style=\"width: 8%;\">Total</th>\n          <th style=\"width: 8%;\">Cut To<br>Ship</th>\n        </tr>\n      </thead>\n      <tbody>\n        {% for row in doc.table_ocn_details %}\n          <tr>\n            <td>{{ row.style }}</td>\n            <td>{{ row.colour }}</td>\n            <td>{{ row.order_quantity }}</td>\n            <td>{{ row.cut_quantity }}</td>\n            <td></td>\n            <td></td>\n            <td></td>\n            <td>{{ row.ship_quantity }}</td>\n            <td>{{ row.good_garments }}</td>\n            <td>{{ row.rejected_garments }}</td>\n            <td>{{ row.rejected_panels }}</td>\n            <td>{{ row.ship_quantity + row.good_garments + row.rejected_garments + row.rejected_panels }}</td>\n            <td>{{ row.cut_to_ship }}%</td>\n          </tr>\n        {% endfor %}\n        <tr class=\"totals-row\">\n          <td>Total</td>\n          <td></td>\n          <td>{{ doc.total_order_qty }}</td>\n          <td>{{ doc.total_cut_qty }}</td>\n          <td></td>\n          <td></td>\n          <td></td>\n          <td>{{ doc.total_ship_qty }}</td>\n          <td>{{ doc.total_good_garments }}</td>\n          <td>{{ doc.total_rejected_garments }}</td>\n          <td>{{ doc.total_rejected_panels }}</td>\n          <td>{{ doc.cumulative_total }}</td>\n          <td>{{ doc.cut_to_ship_of_order }}%</td>\n        </tr>\n      </tbody>\n    </table>\n\n    <!-- Footer -->\n    <table class=\"footer-table\" border=\"1\" cellpadding=\"3\" cellspacing=\"0\">\n      <tr>\n        <td class=\"footer-notes\" rowspan=\"2\">\n          {{ doc.notes or \"Notes: \" }}\n          <div class=\"factory-head-sign\">Factory Head Sign</div>\n        </td>\n        <td class=\"footer-metrics\">\n          <div class=\"footer-metrics-title\">Cut To Ship of Order</div>\n          <div class=\"footer-metrics-value\">{{ doc.cut_to_ship_of_order }}%</div>\n        </td>\n      </tr>\n    </table>\n\n  </div>\n</div>",
