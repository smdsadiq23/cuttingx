  "doctype": "Print Format",
  "font": null,
  "font_size": 14,
  "format_data": null,
  "html": "<div class=\"label-container\">\n  {% for bundle_row in doc.table_bundle_details %}\n    {% set parent_item = frappe.get_doc(\"Bundle Creation Item\", bundle_row.parent_item_id) %}\n    \n    {% set sales_order = None %}\n    {% if parent_item.sales_order %}\n      {% set sales_order = frappe.get_doc(\"Sales Order\", parent_item.sales_order) %}\n    {% endif %}\n\n    <div class=\"label\">\n      <table>\n        <tr>\n          <td>Bundle No: {{ bundle_row.bundle_id }}</td>\n          <td>OCN: {{ parent_item.sales_order or \"\" }}</td>                \n        </tr>\n        <tr>\n          <td>Style: {{ doc.style_number or \"\" }}</td>\n          <td>Colour: {{ doc.color or \"\" }}</td>\n        </tr>\n        <tr>\n          <td>Size: {{ parent_item.size }}</td>\n          <td>Pcs: {{ bundle_row.unitsbundle or \"\" }}</td>\n        </tr>\n        <tr>\n          <td>Lot No: </td>\n          <td rowspan=\"6\" style=\"text-align: center;\">\n            <img src=\"{{ bundle_row.qrcode_image }}\" alt=\"QR Code\" class=\"qr-img\">\n          </td>\n        </tr>\n        <tr>\n          <td>Shade: {{ bundle_row.shade or \"\" }}</td>\n        </tr>\n        <tr>\n          <td>Component: {{ bundle_row.component or \"\" }}</td>\n        </tr>\n        <tr>\n          <td>Buyer: {{ sales_order.customer if sales_order else \"\" }}</td>\n        </tr>\n      </table>\n    </div>\n  {% endfor %}\n</div>",
